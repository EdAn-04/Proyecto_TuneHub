<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0F172A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TÍTULO -->
        <TextView
            android:text="Servicios Básicos"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- CAMBIO DE ACEITE -->
        <LinearLayout
            android:id="@+id/cardAceite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Cambio de aceite"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Lubricación del motor y cambio de filtro para mejor rendimiento"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q250 - Q450"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- SERVICIO MENOR -->
        <LinearLayout
            android:id="@+id/cardServicioMenor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Servicio menor"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Revisión básica, cambio de filtros y chequeo general"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q400 - Q800"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- SERVICIO MAYOR -->
        <LinearLayout
            android:id="@+id/cardServicioMayor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Servicio mayor"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Mantenimiento completo: motor, frenos, suspensión y diagnóstico"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q900 - Q2,000"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- FRENOS -->
        <LinearLayout
            android:id="@+id/cardFrenos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Frenos"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Cambio de pastillas, discos y revisión del sistema de frenado"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q300 - Q900"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- TREN DELANTERO -->
        <LinearLayout
            android:id="@+id/cardTrenDelantero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Tren delantero"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Revisión y reparación de rótulas, terminales y suspensión delantera"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q500 - Q1,200"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ALINEACIÓN Y BALANCEO -->
        <LinearLayout
            android:id="@+id/cardAlineacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Alineación y balanceo"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Ajuste de dirección y balanceo para evitar desgaste irregular"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Q150 - Q300"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- MECÁNICA GENERAL -->
        <LinearLayout
            android:id="@+id/cardMecanica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:text="Mecánica general"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Diagnóstico y reparación de fallas mecánicas en general"
                android:textColor="#94A3B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Precio: Variable según diagnóstico"
                android:textColor="#22C55E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- BOTÓN -->
        <Button
            android:id="@+id/btnRegresar"
            android:text="Regresar"
            android:backgroundTint="#E10600"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>